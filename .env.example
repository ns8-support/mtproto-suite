# ============ Панель управления ============
# Внешний порт панели (HTTP)
PORT=80

# Учётные данные администратора
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Генерируется автоматически при установке (32 байта hex = 64 символа)
JWT_SECRET=

# PostgreSQL
DB_NAME=mtproto_panel
DB_USER=mtproto
# Генерируется автоматически при установке (16 байт hex = 32 символа)
DB_PASSWORD=

# Таймаут запросов к service-node (мс)
NODE_REQUEST_TIMEOUT_MS=30000

# CORS whitelist (через запятую) — только эти origins могут делать запросы к panel API
# По умолчанию: localhost для разработки
# В production укажите HTTPS домен(ы) вашей панели
# Пример: PANEL_FRONTEND_URL=https://panel.example.com,https://www.panel.example.com
PANEL_FRONTEND_URL=http://localhost:5173,http://localhost:80

# Уровень логирования: debug, info, warn, error
LOG_LEVEL=info

# ============ Сервис-нода (только для режима both/node) ============
# Порт API ноды
NODE_PORT=8443

# Порт прокси (nginx SNI-роутер)
NGINX_PORT=443

# Токен авторизации ноды (генерируется при установке, 32 байта)
AUTH_TOKEN=

# VPN: публичный IP VPN exit-ноды (опционально)
NAT_IP=

# Имя TUN/TAP интерфейса (опционально)
TUNNEL_INTERFACE=
